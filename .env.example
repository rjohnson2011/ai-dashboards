# GitHub Enterprise (GHE) Configuration
# Token: https://va.ghe.com/settings/tokens (scopes: repo, read:org)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_API_ENDPOINT=https://api.va.ghe.com
GITHUB_WEB_ENDPOINT=https://va.ghe.com
GITHUB_OWNER=software
GITHUB_REPO=vets-api

# Admin authentication (for admin endpoints)
ADMIN_TOKEN=your_secure_admin_token_here

# Google Sign-In (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id_here
ALLOWED_EMAIL_DOMAINS=oddball.io,adhocteam.us,va.gov

# Database (optional for development, uses SQLite by default)
# DATABASE_URL=postgresql://user:password@localhost/platform_code_reviews_development

# Rails Configuration
RAILS_MASTER_KEY=your_rails_master_key_here

# Optional: Enable debug logging
# RAILS_LOG_LEVEL=debug